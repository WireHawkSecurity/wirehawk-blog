# Normalize all text files to LF in the repository and on checkout.
* text=auto eol=lf

# Treat binary assets as binary so Git never touches their bytes.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
